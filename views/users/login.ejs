<% layout("/layouts/boilerplates") %>
    <div class="row">
        <div class="col-6 offset-3 ">
            <form method="post" action="/login" novalidate class="needs-validation">
                <h1>Login on Wanderlust</h1>
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input id="Username" type="text" required class="form-control" name="username" />
                    <div class="valid-feedback">
                        Username looks Good
                    </div>
                    <div class="invalid-feedback">
                        ❌ Please provide a email
                    </div>

                    
                     <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input id="password" type="password" required class="form-control" name="password" />
                    <div class="valid-feedback">
                        Password looks Good
                    </div>
                    <div class="invalid-feedback">
                        ❌ Please provide a Password
                    </div>
                    <br>
                    <button class="btn btn-success">Signup</button>
        
            </form>
        </div>
    </div>